# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.certificates/

# Android signing keys
*.jks
*.keystore
*.p12
keystore.properties


# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts


/src/generated/prisma

*.db

# capacitor
capacitor.config.json

# build scripts
/src/app/_api_backup/

# Sentry Config File
.env.sentry-build-plugin

/release

/temp

/prisma/data
/prisma/*.log

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/

# 运行时生成的输出（爬虫数据、HTML 报告、索引）
# 代码模板在根目录 index.html，output/ 下的是运行产物
/output/